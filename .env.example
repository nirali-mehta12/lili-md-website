# ============================================================
# LiLi M.D. website — environment variables
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored and must NEVER be committed.
# ============================================================

# --- Firebase Admin (server-side) ---
# From Firebase console → Project settings → Service accounts →
# "Generate new private key". Paste the three values below.
# Keep the literal \n characters inside the private key string.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# On Firebase App Hosting you can usually omit the client email /
# private key (Application Default Credentials are provided) and set
# only FIREBASE_PROJECT_ID.

# --- Form notification ---
# Where new submissions are emailed. Defaults to admin@lilisolutions.ai.
NOTIFY_EMAIL=admin@lilisolutions.ai

# Firestore collection the "Trigger Email" extension watches.
# Leave as `mail` unless you configured the extension differently.
MAIL_COLLECTION=mail
