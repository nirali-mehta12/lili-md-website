rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // The website writes leads ONLY through the Firebase Admin SDK
    // (server-side, in /api/submit), which bypasses these rules.
    // No browser/client ever touches Firestore directly, so we deny
    // all direct client access as defense-in-depth.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
